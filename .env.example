# Cole aqui a connection string do Neon ou Supabase.
#
# Neon (recomendado para Vercel):
#   postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
#
# Supabase (pooler obrigatório em serverless):
#   postgresql://postgres.[ref]:[password]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
#
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# Segredo para assinar os cookies de sessão JWT (mín. 32 chars).
# Gere com: openssl rand -base64 32
SESSION_SECRET="TROQUE_POR_UM_SEGREDO_FORTE_DE_32_CHARS"

# Chave para proteger a rota /api/reset-demo (chamada pelo cron job da Vercel).
CRON_SECRET="TROQUE_POR_UM_SEGREDO_FORTE"
